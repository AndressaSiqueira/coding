  {
    "type": "function",
    "function": {
      "name": "safeoutputs-missing_data",
      "description": "[safeoutputs] Report that data or information needed to complete the task is not available. Use this when you cannot accomplish what was requested because required data, context, or information is missing.",
      "parameters": {
        "type": "object",
        "properties": {
          "alternatives": {
            "description": "Any workarounds, manual steps, or alternative approaches the user could take (max 256 characters).",
            "type": "string"
